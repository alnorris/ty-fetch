{
  "name": "ty-fetch",
  "version": "0.2.0",
  "description": "Automatic TypeScript types for any REST API. No codegen, no manual types — just fetch.",
  "license": "MIT",
  "keywords": [
    "typescript",
    "fetch",
    "openapi",
    "types",
    "api",
    "swagger",
    "codegen-free"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/alnorris/ty-fetch.git"
  },
  "engines": {
    "node": ">=18"
  },
  "sideEffects": false,
  "main": "index.js",
  "types": "index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ty-fetch": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "base.d.ts",
    "index.js",
    "index.d.ts",
    "plugin.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "tsx --test test/*.test.ts",
    "build": "tsc -p tsconfig.build.json",
    "watch": "tsc -p tsconfig.build.json --watch",
    "lint": "eslint src/ test/",
    "check": "eslint src/ test/",
    "prepare": "npm run build",
    "prepublishOnly": "cp base.d.ts index.d.ts && npm run build",
    "release": "np"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.5.2",
    "eslint": "^10.1.0",
    "np": "^11.0.2",
    "tsx": "^4.21.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.58.0"
  },
  "dependencies": {
    "js-yaml": "^4.1.1"
  }
}
